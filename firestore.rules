rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower()));
    }

    function isSeedAdminEmail() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() in [
          'nektarios.zoumboulakis@gmail.com',
          'admin@gmail.com'
        ];
    }

    function isAuthorizedAdmin() {
      return isAdmin() || isSeedAdminEmail();
    }

    function validStoreRequest(data) {
      return data.keys().hasAll(['storeName', 'location', 'status', 'createdAt'])
        && data.storeName is string
        && data.storeName.size() > 0
        && data.storeName.size() <= 200
        && data.location is string
        && data.location.size() > 0
        && data.location.size() <= 200
        && data.status == 'pending'
        && (!('comments' in data) || (data.comments is string && data.comments.size() <= 2000));
    }

    match /stores/{storeId}/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /shared_lists/{listId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberIds;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerId
        && request.auth.uid in request.resource.data.memberIds;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.memberIds;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;
    }

    match /shared_list_codes/{codeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if false;
    }

    match /admins/{adminId} {
      allow read: if isAuthorizedAdmin();
      allow write: if isAdmin();
      allow create, update: if isSeedAdminEmail()
        && request.auth.token.email.lower() == adminId
        && request.resource.data.email == adminId;
    }

    match /admin_devices/{deviceId} {
      allow read, write: if request.auth != null && request.auth.uid == deviceId;
    }

    match /admin_alert_locks/{lockId} {
      allow read: if isAuthorizedAdmin();
      allow create: if isAuthorizedAdmin()
        && !exists(/databases/$(database)/documents/admin_alert_locks/$(lockId));
      allow update, delete: if false;
    }

    match /admin_notification_leader/{adminId} {
      allow read: if isAuthorizedAdmin();
      allow create, update: if isAuthorizedAdmin()
        && request.auth.uid == adminId;
      allow delete: if false;
    }

    match /app_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /legal_policies/{policyId} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow create, update, delete: if isAdmin();

      match /versions/{versionId} {
        allow read, write: if isAdmin();
      }
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /store_requests/{requestId} {
      allow create: if validStoreRequest(request.resource.data);
      allow read, update: if isAuthorizedAdmin();
      allow delete: if isAdmin();
    }

    match /menu_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /home_ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notification_broadcasts/{broadcastId} {
      allow read: if resource.data.status == 'sent' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /user_notifications/{notificationId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    // conversationId == Firebase Auth uid (one thread per user)
    match /support_conversations/{conversationId} {
      allow read: if request.auth != null
        && (request.auth.uid == conversationId || isAdmin());
      allow create: if request.auth != null
        && request.auth.uid == conversationId;
      allow update: if request.auth != null
        && (request.auth.uid == conversationId || isAdmin());

      match /messages/{messageId} {
        allow read: if request.auth != null
          && (request.auth.uid == conversationId || isAdmin());
        allow create: if request.auth != null
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && (
            (request.auth.uid == conversationId
              && request.resource.data.senderRole == 'user'
              && request.resource.data.senderId == request.auth.uid)
            || (isAdmin()
              && request.resource.data.senderRole == 'admin'
              && request.resource.data.senderId == request.auth.uid)
          );
        allow update, delete: if false;
      }
    }
  }
}
