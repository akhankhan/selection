rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthorizedAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && (
          firestore.exists(
            /databases/(default)/documents/admins/$(request.auth.token.email.lower())
          )
          || request.auth.token.email.lower() in [
            'nektarios.zoumboulakis@gmail.com',
            'admin@gmail.com'
          ]
        );
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /stores/{storeId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthorizedAdmin();
    }

    match /menu_categories/{categoryId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthorizedAdmin();
    }

    match /home_ads/{adId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthorizedAdmin();
    }
  }
}
